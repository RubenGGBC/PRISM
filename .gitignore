# PRISM Project .gitignore

# Go binaries
*.exe
*.exe~
*.dll
*.so
*.so.*
*.dylib

# Go build cache
.cache/
__pycache__/
*.egg-info/
dist/
build/

# Test binaries
*.test
*.out

# Go module files
go.sum

# Database files
*.db
*.db-shm
*.db-wal
code_graph.db
vectors.bin

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.iml

# Node.js / Frontend
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.parcel-cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Environment files
.env
.env.local
.env.*.local

# OS files
Thumbs.db
.DS_Store
ehthumbs.db

# Logs
logs/
*.log
mcp_server.log

# Temporary files
*.tmp
*.temp
*.bak
*.swp

# Build artifacts
/prism
/cip
dist/
out/

# Config overrides (keep examples)
claude_desktop_config.json
!mcp/claude_config_example.json

# Test data (optional - uncomment if you have large test files)
# test/sample-repo/large-files/

# LSP/Language server cache
.lsp/

# Vendor directory (if used)
# vendor/

# Local development
.local/
.tmp/
